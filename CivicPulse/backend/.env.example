# Copy to .env (or export in your shell) and fill in.

# SQLite by default; any SQLAlchemy URL works.
DATABASE_URL=sqlite:///./civicpulse.db

# Shared secret for the admin dashboard + admin API endpoints.
ADMIN_TOKEN=change-me

# Anthropic API key — enables AI summaries of articles when drafting
# messages to Congress. Optional: without it a plain template is used.
ANTHROPIC_API_KEY=

# Apple Push Notifications (token-based auth). Optional: without these,
# pushes are logged but not sent.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_PATH=./AuthKey.p8
APNS_TOPIC=org.techoversight.civicpulse
# "sandbox" while developing, "production" for TestFlight/App Store builds.
APNS_ENV=sandbox
